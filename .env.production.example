# ── Digital Twin Simulation Lab — Production Environment ──────────────────
# Copy to .env and fill in real values.

# ── Application ────────────────────────────────────────────────────────────
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8017
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# ── Critical — must be set ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/digital_twin_lab

# ── Observability ──────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=digital-twin-simulation-lab

# ── Integrations ───────────────────────────────────────────────────────────
RACE_COMMAND_URL=http://race-command-center:8020
DOCUMENTATION_URL=https://docs.example.com
SECURITY_POLICY_URL=https://security.example.com
OBSERVABILITY_URL=http://observability-platform:9010
PIPELINES_URL=http://kdd-pipelines:8080

# ── Data ───────────────────────────────────────────────────────────────────
DATA_DIR=/data/digital-twin-lab

# ── Feature flags ──────────────────────────────────────────────────────────
METRICS_ENABLED=true
TRACES_ENABLED=true
